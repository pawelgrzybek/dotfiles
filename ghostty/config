command = /opt/homebrew/bin/fish
macos-option-as-alt = left

font-family = Monaspace Neon NF
font-style = Regular
font-style-bold = Bold
font-style-italic = Italic
font-style-bold-italic = Bold Italic
font-feature === "'calt', 'ss01', 'ss02', 'ss03', 'ss04', 'ss05', 'ss06', 'ss07', 'ss08', 'ss09', 'ss10', 'liga'",
font-size = 14
font-thicken = true
adjust-cell-height = 20
adjust-underline-position = 8
# ideally change bar to block and remove the below
adjust-cursor-thickness = 4
adjust-underline-thickness = 1
adjust-cursor-height = 20
cursor-style = block
mouse-hide-while-typing = true
maximize = true
window-padding-x = 7
window-padding-y = 7
window-padding-balance = true

theme = light:oktheme,dark:oktheme
cursor-style-blink = false
background-opacity = 0.97
background-blur-radius = 20
unfocused-split-opacity = 0.5

# i think claude code set this one for me
keybind = shift+enter=text:\n

# jump quickly between tabs and splits
keybind = super+bracket_left=previous_tab
keybind = super+bracket_right=next_tab
keybind = super+alt+bracket_left=goto_split:previous
keybind = super+alt+bracket_right=goto_split:next

keybind = global:ctrl+alt+t=toggle_quick_terminal

# split
keybind = cmd+d=activate_key_table:split
keybind = split/j=deactivate_key_table
keybind = chain=new_split:down
keybind = split/k=deactivate_key_table
keybind = chain=new_split:up
keybind = split/h=deactivate_key_table
keybind = chain=new_split:left
keybind = split/l=deactivate_key_table
keybind = chain=new_split:right
keybind = split/cmd+d=deactivate_key_table
keybind = split/escape=deactivate_key_table
keybind = resize/catch_all=ignore

# resize
keybind = resize/k=resize_split:up,10
keybind = resize/j=resize_split:down,10
keybind = resize/h=resize_split:left,10
keybind = resize/l=resize_split:right,10
keybind = resize/escape=deactivate_key_table
keybind = resize/catch_all=ignore

keybind = super+r=activate_key_table:resize

